<div class="homepage__row homepage__row--gray homepage__back">
    <a href="{{ back.link }}">
        <span class="fa fa-chevron-left"></span> {{ back.title|raw }}
    </a>
</div>
<div class="homepage__row homepage__row--gray">
    <p class="homepage__text homepage__text--centered homepage__text--title">
        {{ firstpwd.title }}
    </p>
</div>
<div class="homepage__row homepage__row--gray">
    <p class="homepage__text homepage__text--left">
        {{ firstpwd.istruction }}
    </p>
</div>
<div class="homepage__form homepage__form--first-pwd">
    {{ firstpwd.form|raw }}
</div>
<br>
<div class="homepage__row homepage__row--footer">
    <nav class="homepage__links">
        {% if externalPages is defined %}
            {% for externalPage in externalPages %}
                <a href="{{ externalPage.link }}">{{ externalPage.title }}</a>
            {% endfor %}
        {% endif %}
    </nav>
</div>
